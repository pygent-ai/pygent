          "-A": { "type": "number", "description": "匹配后上下文行数" },
          "-C": { "type": "number", "description": "前后上下文行数" },
          "-i": { "type": "boolean", "description": "忽略大小写" },
          "type": { "type": "string", "description": "文件类型" },
          "head_limit": { "type": "number", "description": "结果上限" },
          "offset": { "type": "number", "description": "跳过条数" },
          "multiline": { "type": "boolean", "description": "跨行匹配" }
        },
        "required": ["pattern"]
      }
    }
  },
